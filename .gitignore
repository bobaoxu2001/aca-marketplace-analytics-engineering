# Raw CMS files are large and should be downloaded locally.
data/raw/**/*.csv
data/raw/**/*.csv.gz
data/raw/**/*.zip
data/raw/**/*.parquet

# Processed local warehouse artifacts.
data/processed/*
!data/processed/.gitkeep
*.duckdb
*.duckdb.wal

# dbt build outputs and logs.
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/logs/
dbt_project/.user.yml
logs/

# Research benchmark generated outputs.
research/metric_grounded_llm_agents/benchmark/gold_answers/*
!research/metric_grounded_llm_agents/benchmark/gold_answers/.gitkeep
!research/metric_grounded_llm_agents/benchmark/gold_answers/README.md
research/metric_grounded_llm_agents/evaluation/results/*
!research/metric_grounded_llm_agents/evaluation/results/.gitkeep
!research/metric_grounded_llm_agents/evaluation/results/README.md
!research/metric_grounded_llm_agents/evaluation/results/download_failure_report.json
!research/metric_grounded_llm_agents/evaluation/results/socrata_download_report.json
research/metric_grounded_llm_agents/evaluation/human_review_v1/human_review_key.json

# Python caches and environments.
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Local environment files.
.env
.env.*

# Applicant-internal planning notes (never publish)
applicant_private/

# Local active model config (no secrets; key stays in env)
research/metric_grounded_llm_agents/configs/model_config.yaml
.venv.x86-broken/
